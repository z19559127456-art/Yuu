{
  "name": "vx-agent-collective",
  "version": "0.5.0",
  "description": "vx版Agent集合体 - Frontend",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --dir --win",
    "electron:build:nsis": "electron-builder --win"
  },
  "dependencies": {
    "dayjs": "^1.11.0",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.290.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^6.20.0",
    "ws": "^8.14.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.5",
    "vitest-dom": "^0.1.1"
  },
  "build": {
    "appId": "com.vx-agent-collective.app",
    "productName": "vx版Agent集合体",
    "copyright": "Copyright © 2026 vx Agent Collective",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!venv/**", "!chromadb_store/**", "!__pycache__/**", "!*.pyc", "!tests/**"]
      }
    ],
    "win": {
      "target": {
        "target": "nsis",
        "arch": ["x64"]
      },
      "signAndEditExecutable": false,
      "sign": false,
      "icon": "public/icon.ico",
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052",
      "displayLanguageSelector": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "vx版Agent集合体",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "license": "LICENSE.md",
      "installerSidebar": null,
      "deleteAppDataOnUninstall": false,
      "unicode": true,
      "menuCategory": false,
      "multiLanguageInstaller": false,
      "differentialPackage": false
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      "icon": "public/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": {
        "target": "AppImage",
        "arch": ["x64"]
      },
      "icon": "public/icon-256.png",
      "category": "Office",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
