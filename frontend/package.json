{
  "name": "yu",
  "version": "0.1.11",
  "description": "Yu - AI Agent 桌面平台",
  "author": "Yu",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --dir --win",
    "electron:build:nsis": "electron-builder --win"
  },
  "dependencies": {
    "dayjs": "^1.11.0",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.290.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^6.20.0",
    "ws": "^8.14.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.5",
    "vitest-dom": "^0.1.1"
  },
  "build": {
    "appId": "com.yu.app",
    "productName": "Yu",
    "copyright": "Copyright © 2026 Yu",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "z19559127456-art",
      "repo": "Yu"
    },
    "extraResources": [
      {
        "from": "../backend/dist/yu-backend.exe",
        "to": "backend/yu-backend.exe"
      },
      {
        "from": "../backend/security_policies",
        "to": "backend/security_policies"
      }
    ],
    "win": {
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      "signAndEditExecutable": false,
      "sign": "scripts/dummy-sign.js",
      "icon": "public/icon.ico",
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052",
      "displayLanguageSelector": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yu",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "license": "LICENSE.md",
      "installerSidebar": null,
      "deleteAppDataOnUninstall": false,
      "unicode": true,
      "menuCategory": false,
      "multiLanguageInstaller": false,
      "differentialPackage": false
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      "icon": "public/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": {
        "target": "AppImage",
        "arch": [
          "x64"
        ]
      },
      "icon": "public/icon-256.png",
      "category": "Office",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
